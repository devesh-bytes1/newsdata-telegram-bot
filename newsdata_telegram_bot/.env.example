# Telegram Bot API token from @BotFather (https://t.me/botfather)
TELEGRAM_BOT_TOKEN=

# NewsData.io API key from https://newsdata.io/register (looks like pub_xxxxxxxx)
NEWSDATA_API_KEY=

# Optional: news language code (en, es, fr, de, hi, ...). Default: en
DEFAULT_LANGUAGE=en

# Optional: number of articles per request (1-10). Default: 5
DEFAULT_NEWS_COUNT=5
